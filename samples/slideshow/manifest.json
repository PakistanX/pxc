{
  "name": "slideshow",
  "capabilities": {
    "storage": {
      "media": {
        "scope": "activity"
      }
    }
  },
  "fields": {
    "slides_html": {
      "type": "string",
      "scope": "activity",
      "default": ""
    }
  },
  "actions": {
    "config.save": {
      "type": "object",
      "properties": {
        "slides_html": {
          "type": "string"
        }
      }
    },
    "file.upload": {
      "type": "object",
      "properties": {
        "filename": { "type": "string" },
        "data": { "type": "string" }
      }
    },
    "file.delete": {
      "type": "object",
      "properties": {
        "filename": { "type": "string" }
      }
    }
  },
  "events": {
    "fields.change.slides_html": {
      "type": "string"
    },
    "files.changed": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "filename": { "type": "string" },
          "url": { "type": "string" }
        }
      }
    }
  },
  "assets": [
    "assets/reveal/reset.css",
    "assets/reveal/reveal.css",
    "assets/reveal/theme/white.css",
    "assets/reveal/reveal.js",
    "assets/reveal/theme/fonts/source-sans-pro/source-sans-pro.css",
    "assets/reveal/theme/fonts/source-sans-pro/source-sans-pro-italic.woff",
    "assets/reveal/theme/fonts/source-sans-pro/source-sans-pro-regular.woff",
    "assets/reveal/theme/fonts/source-sans-pro/source-sans-pro-semibold.woff"
  ],
  "ui": "ui.js",
  "sandbox": "sandbox.wasm"
}
