{
  "name": "youtube",
  "fields": {
    "video_id": {
      "type": "string",
      "scope": "activity",
      "default": ""
    },
    "start_time": {
      "type": "integer",
      "scope": "activity",
      "default": 0
    }
  },
  "actions": {
    "config.save": {
      "type": "object",
      "properties": {
        "video_id": {
          "type": "string"
        },
        "start_time": {
          "type": "integer"
        }
      }
    }
  },
  "events": {
    "fields.change.video_id": {
      "type": "string"
    },
    "fields.change.start_time": {
      "type": "integer"
    }
  },
  "ui": "ui.js",
  "sandbox": "sandbox.wasm"
}
